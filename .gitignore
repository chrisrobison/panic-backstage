.env
storage/uploads/events/*
!storage/uploads/events/.gitkeep
storage/logs/*
!storage/logs/.gitkeep
storage/mail/*
!storage/mail/.gitkeep
storage/config/*
!storage/config/.gitkeep
.DS_Store
tests/.state
scripts/__pycache__/
storage/tmp/
storage/backups/
# Generated contract PDFs — signer names/emails/signatures (PII), and
# regenerable on demand from contracts/contract_sections/contract_signers
# (see scripts/regenerate-contract-pdf.php) if ever lost from disk.
storage/contracts/
# Uploaded W-9s — highly sensitive (SSN/EIN) PII; never committed. See
# PayeeSubmissionEndpoint::storeW9() and the storage/ block in .htaccess.
storage/payees/
dns.log
database/mabevents-import.sql
# Ticketing "Fan View" export — real customer PII; import locally, never commit.
database/fanview.csv
