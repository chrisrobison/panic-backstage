Options -Indexes
RewriteEngine On

# Never let the browser hold a stale HTML shell. The shell references its JS/CSS
# with ?v= cache-busting query strings, so if index.html itself is cached the
# version bump never reaches the client and they run old code. Force HTML to
# revalidate on every load; the versioned assets can still cache normally.
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # The frontend is an ES-module graph: index.html versions the entry points
  # (app.js?v=N, app.css?v=N), but those files import submodules with bare
  # specifiers (import './event-views.js') that carry no ?v=. Without an explicit
  # policy the browser caches them heuristically and a changed submodule can be
  # served stale even after the entry-point version is bumped. "no-cache" keeps
  # them cached but forces revalidation (cheap 304s when unchanged) before use,
  # so any edited module is always picked up. The ?v= bumps remain as a belt-and-
  # suspenders signal for upstream proxies/CDNs.
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Security: block direct web access to the per-tenant client data tree ──────
# clients/ sits outside public/ but is still under the document root, so Apache
# would serve it if no rule intervened. Return 403 for any direct /clients/ hit;
# legitimate access always goes through the /files/ gateway below.
RewriteRule ^clients/ - [F,L]

# ── Per-tenant file gateway ───────────────────────────────────────────────────
# /files/{path} is resolved by files.php which looks up the tenant slug from
# the current hostname, validates the path, and streams the file.
# This keeps clients/{slug}/ outside the web root while still serving assets,
# mail attachments, and contract PDFs under a clean per-tenant URL.
RewriteRule ^files/(.+)$ public/files.php?_path=$1 [L,QSA]

RewriteRule ^$ public/index.html [L]
RewriteRule ^(assets|uploads)/(.*)$ public/$1/$2 [L]
RewriteRule ^api(?:/(.*))?$ public/api/index.php [L,QSA]
# Public ticket-view pretty URLs (/t/{token}) must reach the PHP kernel, not
# the SPA catch-all below. Mirror the rule in public/.htaccess here so the
# root-level rewrite engine sees it before falling through to index.html.
RewriteRule ^t(?:/(.*))?$ public/api/index.php [L,QSA]
RewriteRule ^(login|event|invite|scanner|sign)\.html$ public/$1.html [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^.*$ public/index.html [L]
