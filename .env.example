DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=panic_backstage
APP_BASE_PATH=
APP_URL=http://localhost
JWT_SECRET=generate-with-openssl-rand-hex-48
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME=Backstage

# ─── Ticketing / payment providers ───────────────────────────────────────────
# The active provider is selected at runtime in the payment_settings table; the
# keys below are the (secret) credentials each provider needs. Only the active
# provider's keys must be populated, but webhooks/refunds for historical orders
# use whichever provider processed them, so keep keys for any provider you've
# ever taken payments with.

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=your_stripe_secret_key
# Endpoint signing secret from the Stripe webhook settings (starts with whsec_)
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret

# Square (https://developer.squareup.com/apps)
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key
# 'sandbox' or 'production' — switches the Square API base URL
SQUARE_ENV=sandbox
# Exact notification URL configured in the Square webhook subscription; used to
# verify the x-square-hmacsha256-signature. If unset, the live request URL is
# used as a best-effort fallback.
SQUARE_WEBHOOK_URL=https://yourdomain.com/api/webhooks/square
