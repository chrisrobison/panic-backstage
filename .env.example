# ── Single-tenant mode ────────────────────────────────────────────────────────
# Used when SUPER_DB_NAME is NOT set. This is the original standalone install
# configuration — all existing deploys use only these vars.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=panic_backstage
APP_BASE_PATH=
APP_URL=http://localhost
JWT_SECRET=generate-with-openssl-rand-hex-48

# ── Credential encryption ─────────────────────────────────────────────────────
# 64-character hex string (32 bytes) used to encrypt Promote OAuth tokens
# and API keys at rest using libsodium secretbox (XSalsa20-Poly1305).
# Required for the encryption feature; app runs without it but tokens are
# stored in plaintext (dev/legacy mode).
#
# Generate with: php -r "echo bin2hex(random_bytes(32)) . PHP_EOL;"
# After generating, run: php scripts/encrypt-credentials.php
#
# Key rotation: add CREDENTIAL_ENCRYPTION_KEY_NEW=<new-hex> then run:
#   php scripts/rotate-credential-keys.php
# After successful rotation, move NEW to CREDENTIAL_ENCRYPTION_KEY.
CREDENTIAL_ENCRYPTION_KEY=
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME=Backstage

# ── Venue identity ────────────────────────────────────────────────────────────
# These values are used throughout the app wherever a venue name or contact is
# needed: email subjects, social-media copy, promote sign-offs, address fallbacks.
#
# In single-tenant mode, set these here.
# In multi-tenant (SaaS) mode, place overrides in clients/{slug}/.env so each
# tenant gets its own values without touching the shared global config.
#
VENUE_NAME=My Venue
# Public-facing contact email (used as From address for promote email blasts)
VENUE_EMAIL=hello@myvenue.com
# Website URL shown in copy and press releases
VENUE_WEBSITE=https://myvenue.com
# City and state — used as address fallback in Luma / Eventbrite submissions
VENUE_CITY=
VENUE_STATE=
# Press / media contact email for press release copy
VENUE_PRESS_EMAIL=press@myvenue.com
# Comma-separated hashtags (no #) for social-media copy.
# Example: LiveMusic,MyVenue,SFMusic,BayAreaMusic
VENUE_HASHTAGS=LiveMusic
# TikTok handle (without @) — used to build post URLs after broadcasting.
# Also configurable per-venue in Promote Settings → TikTok → handle field.
VENUE_TIKTOK_HANDLE=

# ── Multi-tenant SaaS mode ────────────────────────────────────────────────────
# Set SUPER_DB_NAME to enable multi-tenant routing via HTTP_HOST.
# Leave blank (or omit) to keep standard single-tenant behaviour.
#
# When active, every request to XXX.panicbackstage.com is resolved against the
# super registry and routed to the XXX tenant database. The DB_* vars above are
# ignored in SaaS mode.
#
# Super-admin registry database (stores tenants + tenant_domains tables).
SUPER_DB_NAME=
SUPER_DB_HOST=127.0.0.1
SUPER_DB_PORT=3306
SUPER_DB_USER=root
SUPER_DB_PASSWORD=
#
# Runtime tenant connections — needs SELECT/INSERT/UPDATE/DELETE on panic_backstage_*.
# Falls back to SUPER_DB_* if left blank (convenient for single-server dev installs).
TENANT_DB_HOST=127.0.0.1
TENANT_DB_PORT=3306
TENANT_DB_USER=
TENANT_DB_PASSWORD=
#
# Provisioning credentials — needs CREATE DATABASE + DDL on panic_backstage_*.
# Used by scripts/migrate.php and TenantProvisioner when creating new tenants.
# Falls back to SUPER_DB_* if PROVISION_DB_USER is blank.
PROVISION_DB_HOST=127.0.0.1
PROVISION_DB_PORT=3306
PROVISION_DB_USER=
PROVISION_DB_PASSWORD=
#
# Hostname allow-list (comma-separated). Supports *.domain.com wildcard prefix.
ALLOWED_HOSTS=localhost,127.0.0.1,panicbackstage.com,*.panicbackstage.com
#
# Set to true when the app sits behind a reverse proxy that sets X-Forwarded-Host.
TRUST_PROXY=false
#
# Optional: restrict /super and /api/super to this hostname only.
# When blank, those paths are served from any allowed host (legacy behaviour).
SUPER_HOST=

# ── Private event workflow ────────────────────────────────────────────────────
# New private events are auto-assigned to this user (by DB user ID) and trigger
# an inquiry notification to all venue_admins. Defaults to the first venue_admin
# if unset.
PRIVATE_EVENT_HANDLER_USER_ID=
PRIVATE_EVENT_HANDLER_EMAIL=

# ── Intake Complete notifications ─────────────────────────────────────────────
# When any event reaches Intake Complete, this person is notified alongside the
# venue_admins so they can co-sign and send the contract. Typically the venue
# manager who reviews and countersigns all contracts before they go to the artist.
VENUE_MANAGER_NAME=
VENUE_MANAGER_EMAIL=

# ─── Digital signature ────────────────────────────────────────────────────────
# Provider to use for contract e-signatures.
#   internal     — magic-link flow built into Panic Backstage (default; no external service)
#   mock         — dev/test simulator; no external calls
#   dropbox_sign — Dropbox Sign REST API (needs SIGNATURE_PROVIDER_API_KEY)
#   docusign     — not yet implemented
SIGNATURE_PROVIDER=internal

# How long (in hours) a signing link remains valid before it expires.
# Default: 168 hours (7 days).
SIGNATURE_TOKEN_TTL_HOURS=168

# Webhook signing secret — verifies inbound webhooks came from the provider.
# Dropbox Sign: the "Event Callback" secret from the API dashboard.
SIGNATURE_WEBHOOK_SECRET=

# External provider API credentials (only needed for dropbox_sign/docusign).
SIGNATURE_PROVIDER_API_KEY=
SIGNATURE_PROVIDER_CLIENT_ID=
SIGNATURE_PROVIDER_CLIENT_SECRET=
# Override the provider API base URL (leave blank to use production default).
SIGNATURE_PROVIDER_BASE_URL=

# ─── Ticketing / payment providers ───────────────────────────────────────────
# The active provider is selected at runtime in the payment_settings table; the
# keys below are the (secret) credentials each provider needs. Only the active
# provider's keys must be populated, but webhooks/refunds for historical orders
# use whichever provider processed them, so keep keys for any provider you've
# ever taken payments with.

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=your_stripe_secret_key
# Endpoint signing secret from the Stripe webhook settings (starts with whsec_)
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret

# Square (https://developer.squareup.com/apps)
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key
# 'sandbox' or 'production' — switches the Square API base URL
SQUARE_ENV=sandbox
# Exact notification URL configured in the Square webhook subscription; used to
# verify the x-square-hmacsha256-signature. If unset, the live request URL is
# used as a best-effort fallback.
SQUARE_WEBHOOK_URL=https://yourdomain.com/api/webhooks/square

# ── CRM follow-up reminders ───────────────────────────────────────────────────
# Random secret for the /api/crm-followups cron endpoint.
# Generate: openssl rand -hex 24
# Call daily: curl -X POST -H "X-Cron-Secret: $CRON_SECRET" https://yourdomain.com/api/crm-followups
CRON_SECRET=
