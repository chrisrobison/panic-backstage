<div class="page-head">
  <h1>Event Templates</h1>
  <a class="button" href="/templates/new">New template</a>
</div>
<section class="card-grid">
  <% templates.forEach(template => { %>
    <article class="panel">
      <h2><%= template.name %></h2>
      <p><%= template.event_type.replaceAll('_',' ') %> · <%= template.venue_name %></p>
      <form method="post" action="/events/from-template/<%= template.id %>" class="grid-form compact">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="date" name="date" required>
        <input type="time" name="doors_time" value="19:00">
        <input type="time" name="show_time" value="20:00">
        <input name="title" value="<%= template.default_title || template.name %>">
        <button>Create event</button>
      </form>
    </article>
  <% }) %>
</section>
