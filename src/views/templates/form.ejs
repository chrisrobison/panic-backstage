<div class="page-head"><h1>New Template</h1><a href="/templates">Back</a></div>
<section class="panel">
  <form method="post" action="/templates" class="grid-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Name <input name="name" required></label>
    <label>Venue <select name="venue_id"><% venues.forEach(v => { %><option value="<%= v.id %>"><%= v.name %></option><% }) %></select></label>
    <label>Type <select name="event_type"><% eventTypes.forEach(t => { %><option value="<%= t %>"><%= t.replaceAll('_',' ') %></option><% }) %></select></label>
    <label>Default title <input name="default_title"></label>
    <label>Ticket price <input type="number" step="0.01" name="default_ticket_price" value="0"></label>
    <label>Age restriction <input name="default_age_restriction"></label>
    <label class="wide">Public description <textarea name="default_description_public"></textarea></label>
    <label class="wide">Checklist JSON <textarea name="checklist_json">[]</textarea></label>
    <label class="wide">Schedule JSON <textarea name="schedule_json">[]</textarea></label>
    <button>Save template</button>
  </form>
</section>
