<article class="public-event">
  <% if (flyer) { %><img class="public-flyer" src="<%= flyer.file_path %>" alt="<%= event.title %> flyer"><% } %>
  <div class="public-copy">
    <p class="eyebrow"><%= event.date.toISOString ? event.date.toISOString().slice(0,10) : event.date %> · <%= event.venue_name %></p>
    <h1><%= event.title %></h1>
    <p><strong>Doors</strong> <%= event.doors_time || 'TBA' %> · <strong>Show</strong> <%= event.show_time || 'TBA' %></p>
    <p><%= event.age_restriction || 'All ages unless noted' %> · <%= Number(event.ticket_price) > 0 ? `$${event.ticket_price}` : 'Free / door' %></p>
    <% if (event.ticket_url) { %><a class="button" href="<%= event.ticket_url %>">Tickets</a><% } %>
    <p><%= event.description_public || '' %></p>
    <% if (lineup.length) { %>
      <h2>Lineup</h2>
      <ul class="plain-list"><% lineup.forEach(item => { %><li><%= item.display_name %> <% if (item.set_time) { %><span><%= item.set_time %></span><% } %></li><% }) %></ul>
    <% } %>
    <p class="muted"><%= event.address %>, <%= event.city %>, <%= event.state %></p>
  </div>
</article>
