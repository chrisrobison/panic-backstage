<div class="page-head">
  <div>
    <h1>Operations Dashboard</h1>
    <p class="muted">Next 14 days, blockers, assets, ticketing, and settlement gaps.</p>
  </div>
  <a class="button" href="/events/new">New event</a>
</div>

<section class="metric-grid">
  <a class="metric" href="/events?status=hold"><strong><%= cards.empty %></strong><span>Empty / hold nights</span></a>
  <a class="metric" href="/events?status=needs_assets"><strong><%= cards.needsAssets %></strong><span>Need flyers/assets</span></a>
  <a class="metric" href="/events?status=ready_to_announce"><strong><%= cards.ready %></strong><span>Ready to announce</span></a>
  <a class="metric danger" href="/events"><strong><%= cards.blockers %></strong><span>Events with blockers</span></a>
  <a class="metric" href="/events?status=published"><strong><%= cards.published %></strong><span>Upcoming published</span></a>
  <a class="metric warn" href="/events?status=completed"><strong><%= cards.unsettled %></strong><span>Completed, unsettled</span></a>
</section>

<section class="panel">
  <h2>Next 14 Days</h2>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Date</th><th>Event</th><th>Type</th><th>Status</th><th>Owner</th><th>Blocked</th><th>Tasks / Assets</th><th></th></tr></thead>
      <tbody>
        <% events.forEach(function(event){ %>
          <tr class="<%= event.primary_blocker ? 'row-blocked' : '' %>">
            <td><%= event.date.toISOString ? event.date.toISOString().slice(0,10) : event.date %></td>
            <td><strong><%= event.title %></strong></td>
            <td><%= event.event_type.replaceAll('_', ' ') %></td>
            <td><%- include('../partials/status-badge', { status: event.status }) %></td>
            <td><%= event.owner_name || 'Unassigned' %></td>
            <td><%= event.primary_blocker || 'Clear' %></td>
            <td><%= event.incomplete_tasks %> open / <%= event.approved_flyers ? 'flyer approved' : 'missing flyer' %></td>
            <td><a href="/events/<%= event.id %>">Open</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
