<div class="page-head">
  <h1>Events</h1>
  <a class="button" href="/events/new">New event</a>
</div>
<section class="panel">
  <form class="filters" method="get">
    <input type="date" name="start_date" value="<%= filters.start_date || '' %>">
    <input type="date" name="end_date" value="<%= filters.end_date || '' %>">
    <select name="status"><option value="">Any status</option><% enums.statuses.forEach(s => { %><option value="<%= s %>" <%= filters.status===s?'selected':'' %>><%= s.replaceAll('_',' ') %></option><% }) %></select>
    <select name="event_type"><option value="">Any type</option><% enums.types.forEach(t => { %><option value="<%= t %>" <%= filters.event_type===t?'selected':'' %>><%= t.replaceAll('_',' ') %></option><% }) %></select>
    <select name="owner_user_id"><option value="">Any owner</option><% users.forEach(u => { %><option value="<%= u.id %>" <%= String(filters.owner_user_id)===String(u.id)?'selected':'' %>><%= u.name %></option><% }) %></select>
    <select name="public_visibility"><option value="">Any visibility</option><option value="1" <%= filters.public_visibility==='1'?'selected':'' %>>Public</option><option value="0" <%= filters.public_visibility==='0'?'selected':'' %>>Internal</option></select>
    <button>Filter</button>
  </form>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Date</th><th>Title</th><th>Type</th><th>Status</th><th>Owner</th><th>Public</th><th></th></tr></thead>
      <tbody>
        <% events.forEach(event => { %>
          <tr>
            <td><%= event.date.toISOString ? event.date.toISOString().slice(0,10) : event.date %></td>
            <td><%= event.title %></td>
            <td><%= event.event_type.replaceAll('_',' ') %></td>
            <td><%- include('../partials/status-badge', { status: event.status }) %></td>
            <td><%= event.owner_name || 'Unassigned' %></td>
            <td><%= event.public_visibility ? 'Yes' : 'No' %></td>
            <td><a href="/events/<%= event.id %>">Workspace</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
