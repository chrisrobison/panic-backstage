<%
  const fmt = function(value, opts) {
    const d = value && value.toISOString ? value : new Date(value);
    return d.toLocaleDateString('en-US', opts || { month: 'short', day: 'numeric' });
  };
  const byDay = {};
  events.forEach(function(event) {
    const key = (event.date && event.date.toISOString ? event.date.toISOString() : String(event.date)).slice(0,10);
    byDay[key] = byDay[key] || [];
    byDay[key].push(event);
  });
  const today = new Date();
  const first = new Date(today.getFullYear(), today.getMonth(), 1);
  const calendarStart = new Date(first);
  calendarStart.setDate(first.getDate() - first.getDay());
  const cells = [];
  for (let i = 0; i < 35; i++) {
    const d = new Date(calendarStart);
    d.setDate(calendarStart.getDate() + i);
    cells.push(d);
  }
  const groups = [
    ['Empty', 'empty'],
    ['Proposed', 'proposed'],
    ['Hold', 'hold'],
    ['Confirmed', 'confirmed'],
    ['Needs Assets', 'needs_assets'],
    ['Ready to Announce', 'ready_to_announce'],
    ['Published', 'published'],
    ['Advanced', 'advanced']
  ];
%>

<div class="page-head">
  <div>
    <h1>Calendar & Pipeline</h1>
    <p class="muted">See coverage and move events through the show pipeline.</p>
  </div>
</div>

<form class="filters-bar" method="get">
  <label class="filter-control"><span>▣</span><input type="date" name="start_date" value="<%= filters.start_date || '' %>"><span>–</span><input type="date" name="end_date" value="<%= filters.end_date || '' %>"></label>
  <label class="filter-control">Event Type <select name="event_type"><option value="">All types</option><% enums.types.forEach(t => { %><option value="<%= t %>" <%= filters.event_type===t?'selected':'' %>><%= t.replaceAll('_',' ') %></option><% }) %></select></label>
  <label class="filter-control">Owner <select name="owner_user_id"><option value="">All owners</option><% users.forEach(u => { %><option value="<%= u.id %>" <%= String(filters.owner_user_id)===String(u.id)?'selected':'' %>><%= u.name %></option><% }) %></select></label>
  <label class="filter-control">Status <select name="status"><option value="">All statuses</option><% enums.statuses.forEach(s => { %><option value="<%= s %>" <%= filters.status===s?'selected':'' %>><%= s.replaceAll('_',' ') %></option><% }) %></select></label>
  <button class="secondary">☷ Clear Filters</button>
</form>

<section class="calendar-shell">
  <div class="calendar-toolbar">
    <div class="segmented"><a href="/events">‹</a><a href="/events">›</a><a href="/events">Today</a></div>
    <div class="calendar-title"><%= today.toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %>⌄</div>
    <div class="segmented"><span class="active">Month</span><span>Week</span><a href="/events/new">+ Add Event</a></div>
  </div>
  <div class="calendar-grid">
    <% ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].forEach(function(day){ %><div class="calendar-day-name"><%= day %></div><% }) %>
    <% cells.forEach(function(day){ const key = day.toISOString().slice(0,10); const dayEvents = byDay[key] || []; %>
      <div class="calendar-cell">
        <div class="date"><%= day.getMonth() === today.getMonth() ? day.getDate() : fmt(day) %></div>
        <% if (dayEvents.length) { %>
          <% dayEvents.slice(0,2).forEach(function(event){ %>
            <a class="calendar-event" href="/events/<%= event.id %>"><span class="status-dot <%= event.status %>"></span><%= event.title %><br><%- include('../partials/status-badge', { status: event.status }) %></a>
          <% }) %>
        <% } else { %>
          <a class="program-night" href="/events/new">+ Program This Night</a>
        <% } %>
      </div>
    <% }) %>
  </div>
</section>

<section class="pipeline-board" aria-label="Pipeline">
  <% groups.forEach(function(group){ const list = events.filter(function(event){ return event.status === group[1]; }); %>
    <div class="kanban-column">
      <header><span><%= group[0] %></span><span class="count-pill"><%= list.length %></span></header>
      <% list.slice(0,3).forEach(function(event){ %>
        <a class="pipeline-card" href="/events/<%= event.id %>">
          <strong><%= event.title %></strong>
          <small><%= fmt(event.date, { weekday: 'short', month: 'short', day: 'numeric' }) %></small>
          <small><span class="avatar"><%= (event.owner_name || '—').slice(0,1) %></span><%= event.owner_name || 'Unassigned' %></small>
          <small>◎ 0 blockers &nbsp; ◴ <%= event.public_visibility ? '2' : '1' %> tasks</small>
        </a>
      <% }) %>
      <a class="muted" href="/events/new">+ Add card</a>
    </div>
  <% }) %>
</section>
