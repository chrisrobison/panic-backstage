<div class="page-head">
  <h1><%= event.id ? 'Edit Event' : 'New Event' %></h1>
  <% if (event.id) { %><a href="/events/<%= event.id %>">Back to workspace</a><% } %>
</div>
<section class="panel">
  <form method="post" action="<%= action %>" class="grid-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Title <input name="title" required value="<%= event.title || '' %>"></label>
    <label>Date <input type="date" name="date" required value="<%= event.date ? (event.date.toISOString ? event.date.toISOString().slice(0,10) : event.date) : '' %>"></label>
    <label>Venue <select name="venue_id" required><% venues.forEach(v => { %><option value="<%= v.id %>" <%= String(event.venue_id)===String(v.id)?'selected':'' %>><%= v.name %></option><% }) %></select></label>
    <label>Type <select name="event_type"><% enums.types.forEach(t => { %><option value="<%= t %>" <%= event.event_type===t?'selected':'' %>><%= t.replaceAll('_',' ') %></option><% }) %></select></label>
    <label>Status <select name="status"><% enums.statuses.forEach(s => { %><option value="<%= s %>" <%= (event.status || 'proposed')===s?'selected':'' %>><%= s.replaceAll('_',' ') %></option><% }) %></select></label>
    <label>Owner <select name="owner_user_id"><option value="">Unassigned</option><% users.forEach(u => { %><option value="<%= u.id %>" <%= String(event.owner_user_id)===String(u.id)?'selected':'' %>><%= u.name %></option><% }) %></select></label>
    <label>Doors <input type="time" name="doors_time" value="<%= event.doors_time || '' %>"></label>
    <label>Show <input type="time" name="show_time" value="<%= event.show_time || '' %>"></label>
    <label>End <input type="time" name="end_time" value="<%= event.end_time || '' %>"></label>
    <label>Age restriction <input name="age_restriction" value="<%= event.age_restriction || '' %>"></label>
    <label>Ticket price <input type="number" step="0.01" name="ticket_price" value="<%= event.ticket_price || 0 %>"></label>
    <label>Capacity <input type="number" name="capacity" value="<%= event.capacity || '' %>"></label>
    <label class="wide">Ticket URL <input type="url" name="ticket_url" value="<%= event.ticket_url || '' %>"></label>
    <label class="wide">Public description <textarea name="description_public"><%= event.description_public || '' %></textarea></label>
    <label class="wide">Internal notes <textarea name="description_internal"><%= event.description_internal || '' %></textarea></label>
    <label class="check wide"><input type="checkbox" name="public_visibility" value="1" <%= event.public_visibility ? 'checked' : '' %>> Public page visible</label>
    <button><%= event.id ? 'Save event' : 'Create event' %></button>
  </form>
</section>
