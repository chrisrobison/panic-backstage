<div class="page-head">
  <h1>Invite Collaborator</h1>
  <a href="/events/<%= event.id %>">Back to <%= event.title %></a>
</div>
<section class="panel">
  <form method="post" action="/events/<%= event.id %>/invites" class="grid-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Email <input type="email" name="email" required></label>
    <label>Role <select name="role"><% roles.forEach(role => { %><option value="<%= role %>"><%= role.replaceAll('_',' ') %></option><% }) %></select></label>
    <button>Create invite</button>
  </form>
  <h2>Existing invites</h2>
  <ul class="plain-list"><% invites.forEach(i => { %><li><%= i.email %> as <%= i.role %> <% if (i.used_at) { %>(used)<% } %></li><% }) %></ul>
</section>
